# OperateAI marketing site — environment.
#
# The site runs fine with NONE of these set: the contact / Free-AI-Check forms
# fall back to logging a stub instead of emailing, storing, or list-adding.
# Copy this file to `.env.local` for local dev, and set the same vars in the
# Vercel project settings for production. (Vercel applies new env vars only to
# deployments built AFTER you add them — redeploy after changing.)

# --- Resend: transactional email (the enquiry + Free AI Check forms) -------
# https://resend.com  →  API Keys
# Needs DNS on operateai.com.au (verify the domain in Resend):
#   - DKIM:                TXT  resend._domainkey
#   - Sending return path: MX/TXT  send
#   - DMARC (optional):    TXT  _dmarc
RESEND_API_KEY=
RESEND_FROM_EMAIL="OperateAI <team@operateai.com.au>"
RESEND_TO_EMAIL=team@operateai.com.au

# --- Resend Audience: marketing list ---------------------------------------
# When set (with RESEND_API_KEY), each submitter's email is added to this
# Resend Audience so you can broadcast later. Resend → Audiences → copy the ID.
# Unset = no contact is added (lead email + DB capture still happen).
RESEND_AUDIENCE_ID=

# --- Neon Postgres: durable lead storage -----------------------------------
# Every check/contact submission is stored in a `leads` table (created
# automatically on first write). Neon → project → pooled connection string.
# Unset = capture no-ops (the lead email still sends).
DATABASE_URL=

# --- Analytics (placeholder) ----------------------------------------------
# NOT wired into the code yet — listed here for when analytics is added.
PLAUSIBLE_DOMAIN=operateai.com.au

# --- Optional: server-side auto-draft of the Free AI Check ----------------
# When AUTO_CHECK=1, a form submission triggers the gather→triage→report
# pipeline server-side and emails the operator the draft via RESEND_TO_EMAIL.
# Default is OFF (no pipeline runs, no API cost) — safe to leave unset.
# Set all five keys below in the Vercel project settings to enable.
AUTO_CHECK=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
