# OperateAI marketing site — environment.
#
# The site runs fine with NONE of these set: the contact / Free-AI-Check forms
# fall back to logging a stub instead of emailing. Set RESEND_* to receive real
# enquiries. Copy this file to `.env.local` for local dev, and add the same vars
# in the Vercel project settings for production.

# --- Resend: transactional email (the enquiry + Free AI Check forms) -------
# https://resend.com  →  API Keys
# Needs DNS on operateai.com.au (verify the domain in Resend):
#   - DKIM:               TXT  resend._domainkey
#   - Sending return path: MX/TXT  send
#   - DMARC (optional):    TXT  _dmarc
RESEND_API_KEY=
RESEND_FROM_EMAIL="OperateAI <hello@operateai.com.au>"
RESEND_TO_EMAIL=hello@operateai.com.au

# --- Analytics (placeholder) ----------------------------------------------
# NOT wired into the code yet — listed here for when analytics is added.
# Safe to leave blank.
PLAUSIBLE_DOMAIN=operateai.com.au
